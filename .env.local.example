# Copy to .env.local and fill in. Project ID is public (safe in the browser). Never add API tokens here.

# https://www.sanity.io/manage — create a project, then npx sanity@latest init in this folder if you prefer the CLI
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
